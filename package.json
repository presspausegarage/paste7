{
  "name": "paste7",
  "version": "0.0.0",
  "private": true,
  "description": "Lightweight desktop scratchpad for inspecting healthcare interop messages with PHI auto-redaction. Paste HL7 v2/v3, C-CDA, or FHIR; drop DICOM files; see redacted views in real time. In-memory only.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "tauri": "npm run tauri --workspace=@paste7/app --",
    "dev": "npm run tauri -- dev",
    "dist": "npm run tauri -- build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
